# Copy to .env (gitignored) and fill in your keys.

# --- LLM ---
# Reuse the same Groq key as 01-ai-review-engine
GROQ_API_KEY=

# --- Spotify Web API ---
# Register an app at https://developer.spotify.com/dashboard
# (free tier; "Client Credentials" flow needs only Client ID + Secret)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# For user-authorized flow (optional, signed-in mode)
SPOTIFY_REDIRECT_URI=http://localhost:8501/callback
