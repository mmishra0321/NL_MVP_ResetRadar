# =====================================================================
# Reset Radar backend .env (example)
# Copy this file to `.env` in the SAME folder and fill in your secrets.
# =====================================================================

# --- Groq Cloud (required for non-mock LLM calls) ---
GROQ_API_KEY=

# --- Spotify Developer app credentials (required only when MOCK_MODE=false) ---
# 1. Go to https://developer.spotify.com/dashboard and create an app.
# 2. Edit the app -> Redirect URIs -> add `http://127.0.0.1:8000/auth/callback`.
# 3. Copy the Client ID below. (Client secret is OPTIONAL: Reset Radar uses
#    PKCE on the token exchange, so the secret is never sent over the wire.)
# 4. While the app is in Development Mode, add the listener's Spotify email
#    to "User Management" -> "Allow-list" (up to 25 users without Extended
#    Quota approval).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# --- Session cookie signing (REQUIRED in any non-dev deploy) ---
# Used to sign the `rr_session` cookie that links a browser to a user_id
# after OAuth callback. Generate with:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET_KEY=reset-radar-dev-secret-CHANGE-IN-PROD

# --- Where /auth/callback redirects after a successful login ---
FRONTEND_ORIGIN=http://127.0.0.1:5173

# --- LLM model selection ---
GROQ_MODEL_REASONER=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# --- Mock mode (TRUE is the live-demo default) ---
# When true, the backend reads synthetic_weeks.json + mock_candidates.json
# and never touches the live Spotify Web API. Set to false to enable the
# R4 real-Spotify path (requires the OAuth credentials above + an
# allow-listed Premium account).
MOCK_MODE=true

# --- Persistence ---
DATABASE_URL=sqlite:///./reset_radar.db

# --- Detection trigger thresholds (see architecture.md section 2) ---
STUCK_THRESHOLD=0.6
STUCK_STREAK_WEEKS=3
COOLDOWN_WEEKS=4

# --- Reset session trial window ---
TRIAL_WINDOW_DAYS=10

# --- Operational knobs ---
MAX_CANDIDATES_FROM_SEARCH=80
SPOTIFY_SEARCH_PAGE_SIZE=10
RESET_PLAYLIST_SIZE=20
