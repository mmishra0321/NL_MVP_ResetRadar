# =====================================================================
# Reset Radar backend .env (example)
# Copy this file to `.env` in the SAME folder and fill in your secrets.
# =====================================================================

# --- Groq Cloud (required for non-mock LLM calls) ---
GROQ_API_KEY=

# --- Spotify Developer app credentials (required only when MOCK_MODE=false) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# --- LLM model selection ---
GROQ_MODEL_REASONER=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# --- Mock mode (TRUE is the live-demo default) ---
# When true, the backend reads synthetic_weeks.json + mock_candidates.json
# and never touches the live Spotify Web API. Set to false only for the
# real-Spotify integration test path that lands in R4.
MOCK_MODE=true

# --- Persistence ---
DATABASE_URL=sqlite:///./reset_radar.db

# --- Detection trigger thresholds (see architecture.md section 2) ---
STUCK_THRESHOLD=0.6
STUCK_STREAK_WEEKS=3
COOLDOWN_WEEKS=4

# --- Reset session trial window ---
TRIAL_WINDOW_DAYS=10

# --- Operational knobs ---
MAX_CANDIDATES_FROM_SEARCH=80
SPOTIFY_SEARCH_PAGE_SIZE=10
RESET_PLAYLIST_SIZE=20
